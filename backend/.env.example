# ── Server ────────────────────────────────────────────────
PORT=5000

# ── CORS ──────────────────────────────────────────────────
# Must match the frontend dev server URL exactly.
FRONTEND_URL=http://localhost:5173

# ── Auth ──────────────────────────────────────────────────
# REQUIRED — must be ≥64 random characters in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_generate_a_strong_one

# ── Database ───────────────────────────────────────────────
# Local MongoDB URI (default) or a MongoDB Atlas connection string.
MONGO_URI=mongodb://localhost:27017/megacare